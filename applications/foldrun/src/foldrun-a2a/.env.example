# FoldRun A2A Proxy — Environment Configuration

# GCP Project Configuration
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_REGION=us-central1

# Agent Engine Configuration
# Resource ID for the deployed FoldRun agent in Agent Engine
# Format: projects/<project-num>/locations/<region>/reasoningEngines/<id>
AGENT_ENGINE_RESOURCE=projects/your-project-id/locations/us-central1/reasoningEngines/your-engine-id

# Base URL for the A2A agent (used in the Agent Card)
# Defaults to http://localhost:8080 if not set
# AGENT_BASE_URL=https://your-cloud-run-url.a.run.app

# Optional: Port for the service
PORT=8080
