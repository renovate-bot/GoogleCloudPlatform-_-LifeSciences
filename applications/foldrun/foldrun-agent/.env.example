# ============================================================================
# FoldRun Agent — Environment Configuration (LOCAL DEVELOPMENT ONLY)
# ============================================================================
# This file is ONLY needed for local development (running the agent CLI).
# Deployment via deploy-all.sh / Cloud Build does NOT use .env — all values
# are derived from Terraform outputs and passed via CLI arguments.
#
# To set up for local dev:
#   cp .env.example .env
#   # Edit .env with your project's values
# ============================================================================

# ============================================================================
# Google Cloud Authentication (REQUIRED)
# ============================================================================
# Vertex AI is required for Gemini models. Authenticate locally with:
#   gcloud auth application-default login
# In production (Agent Engine, Cloud Run), this is handled automatically.
GOOGLE_GENAI_USE_VERTEXAI=true

# ============================================================================
# GCP Project Configuration (REQUIRED)
# ============================================================================
# Your GCP project ID (not the project number).
# GOOGLE_CLOUD_PROJECT and GOOGLE_CLOUD_LOCATION are set automatically
# by Agent Engine at runtime; GCP_PROJECT_ID and GCP_REGION are used
# during local development and Cloud Build.
GOOGLE_CLOUD_PROJECT=my-project-id
GOOGLE_CLOUD_LOCATION=global

GCP_PROJECT_ID=my-project-id
GCP_REGION=us-central1
GCP_ZONE=us-central1-a

# ============================================================================
# Google Cloud Storage (REQUIRED)
# ============================================================================
# Main data bucket — stores pipeline outputs, analysis results, job state.
# Terraform creates this as: {project_id}-foldrun-data
GCS_BUCKET_NAME=my-project-id-foldrun-data

# Separate bucket for genetic database backups (downloads + MMseqs2 indexes).
# Terraform creates this as: {project_id}-foldrun-gdbs
# If not set, falls back to GCS_BUCKET_NAME.
# GCS_DATABASES_BUCKET=my-project-id-foldrun-gdbs

# ============================================================================
# Filestore Configuration (REQUIRED)
# ============================================================================
# Filestore instance name (not the full resource path).
# Terraform creates this as defined in variables.tf (default: foldrun-nfs).
FILESTORE_ID=foldrun-nfs

# IP and network are auto-discovered from the Filestore API at runtime.
# Only set these if you need to override auto-discovery:
# FILESTORE_IP=10.0.1.2
# FILESTORE_NETWORK=projects/123456789/global/networks/foldrun-network

# NFS mount configuration — must match the Filestore share name and the
# mount path used in Vertex AI pipelines and Cloud Batch jobs.
NFS_SHARE=/datasets
NFS_MOUNT_POINT=/mnt/nfs/foldrun

# ============================================================================
# AlphaFold Components Image (REQUIRED)
# ============================================================================
# Container image with AlphaFold pipeline components (data pipeline,
# model predict, relax, etc.). Built and pushed by Cloud Build.
# Format: {region}-docker.pkg.dev/{project}/{repo}/alphafold-components:latest
ALPHAFOLD_COMPONENTS_IMAGE=us-central1-docker.pkg.dev/my-project-id/foldrun-repo/alphafold-components:latest

# ============================================================================
# Model Configuration (REQUIRED)
# ============================================================================
# Gemini model for the agent. Preview models require GOOGLE_CLOUD_LOCATION=global.
# Options: gemini-3-flash-preview, gemini-3.1-pro-preview
GEMINI_MODEL=gemini-3-flash-preview

# Gemini model used by analysis Cloud Run Jobs for expert analysis.
# Uses gemini-3.1-pro-preview for higher quality multimodal analysis.
# GEMINI_ANALYSIS_MODEL=gemini-3.1-pro-preview

# ============================================================================
# FoldRun Viewer (OPTIONAL)
# ============================================================================
# URL of the foldrun-viewer Cloud Run service (handles both AF2 and OF3).
# Set automatically during Cloud Build deployment. To get it manually:
#   gcloud run services describe foldrun-viewer --region=us-central1 --format='value(status.url)'
# AF2_VIEWER_URL=https://foldrun-viewer-abc123def-uc.a.run.app

# ============================================================================
# OpenFold3 Components Image (OPTIONAL — enables OF3 predictions)
# ============================================================================
# Container image with OpenFold3 pipeline components. Built and pushed by Cloud Build.
# Optional: OpenFold3 integration
# If not set, agent runs in AF2-only mode (OF3 tools not loaded).
# Format: {region}-docker.pkg.dev/{project}/{repo}/openfold3-components:latest
# OPENFOLD3_COMPONENTS_IMAGE=us-central1-docker.pkg.dev/my-project-id/foldrun-repo/openfold3-components:latest

# OF3 Analysis Job name (Cloud Run Job for parallel analysis)
# OF3_ANALYSIS_JOB_NAME=of3-analysis-job

# Optional: Boltz-2 integration
# If not set, Boltz-2 tools are not loaded.
# BOLTZ2_COMPONENTS_IMAGE=us-central1-docker.pkg.dev/my-project-id/foldrun-repo/boltz2-components:latest
# BOLTZ2_ANALYSIS_JOB_NAME=boltz2-analysis-job
# BOLTZ2_CACHE_PATH=boltz2/cache  # NFS path containing boltz2_conf.ckpt + mols/ (default: boltz2/cache)
# ============================================================================
# GPU Configuration (OPTIONAL)
# ============================================================================
# Comma-separated list of GPU types to use for inference pipelines.
# Auto-detected from your project's GPU quota if not set.
# Common types: L4 (cost-effective), A100 (fastest), T4 (legacy)
# AF2_SUPPORTED_GPUS=L4,A100

# ============================================================================
# Pipeline Scheduling (OPTIONAL)
# ============================================================================
# Max hours DWS FLEX_START will wait per GPU task for provisioning.
# Each predict/relax task waits independently. A monomer pipeline has ~10
# GPU tasks, a multimer up to ~50. Default: 168 (7 days).
# DWS_MAX_WAIT_HOURS=168

# Max concurrent predict/relax tasks per pipeline run.
# Higher values need more GPU quota but finish faster. Default: 5.
# AF2_PARALLELISM=5

# ============================================================================
# Retry Configuration (OPTIONAL)
# ============================================================================
# Max retry attempts for transient 500 errors (default: 3)
AF2_MAX_RETRIES=3

# Initial retry delay in seconds, with exponential backoff (default: 2.0)
AF2_RETRY_DELAY=2.0

# ============================================================================
# Agent Engine Deployment (OPTIONAL — used by deploy.py)
# ============================================================================
# Display name and description shown in the Agent Engine console.
AGENT_ENGINE_DISPLAY_NAME=FoldRun Assistant
AGENT_ENGINE_DESCRIPTION=AI assistant for protein structure prediction (AlphaFold2 + OpenFold3), job management, and results analysis
AGENT_ENGINE_REGION=us-central1

# ============================================================================
# IAP Configuration (OPTIONAL)
# ============================================================================
# Domain to grant access to the foldrun-viewer through IAP.
# Used by deploy-all.sh when running Terraform. If not set, defaults to example.com.
# IAP_ACCESS_DOMAIN=your-domain.com
