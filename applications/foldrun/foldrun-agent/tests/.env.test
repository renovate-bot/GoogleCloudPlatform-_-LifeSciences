# Test environment configuration
# These values are used by the test fixtures in conftest.py

GCP_PROJECT_ID=test-project
GCP_REGION=us-central1
GCP_ZONE=us-central1-a
GCS_BUCKET_NAME=test-af2-bucket
FILESTORE_ID=test-filestore
ALPHAFOLD_COMPONENTS_IMAGE=us-central1-docker.pkg.dev/test-project/foldrun-repo/alphafold-components:latest
GEMINI_MODEL=gemini-3-flash-preview
NFS_SHARE=/datasets
NFS_MOUNT_POINT=/mnt/nfs/foldrun
AF2_SUPPORTED_GPUS=L4,A100,A100_80GB
